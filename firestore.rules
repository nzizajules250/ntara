rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // HELPERS (SAFE + NON-BREAKING)
    // =====================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isOwner(userId) {
      return isSignedIn() && uid() == userId;
    }

    function userDocExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(uid()));
    }

    function getRole() {
      return userDocExists()
        ? get(/databases/$(database)/documents/users/$(uid())).data.role
        : null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // =====================================================
    // USERS COLLECTION
    // =====================================================

    match /users/{userId} {

      function isValidUser(data) {
        return data.uid == userId
          && data.name is string
          && data.name.size() > 0
          && data.name.size() <= 100
          && data.role in ['passenger', 'rider'];
      }

      // Read any authenticated user
      allow get: if isSignedIn();

      // Create only own profile
      allow create: if isSignedIn()
        && userId == uid()
        && isValidUser(incoming());

      // Update only own profile
      allow update: if isSignedIn()
        && userId == uid()
        && isValidUser(incoming());

      allow list: if isSignedIn();
    }

    // =====================================================
    // RIDES COLLECTION
    // =====================================================

    match /rides/{rideId} {

      function isValidRide(data) {
        return isSignedIn()
          && data.passengerId == uid()
          && data.status in [
            'requested',
            'accepted',
            'arrived',
            'ongoing',
            'completed',
            'cancelled'
          ]
          && data.fare is number
          && data.pickup.lat is number
          && data.pickup.lng is number
          && data.destination.lat is number
          && data.destination.lng is number;
      }

      // -----------------------------------------------------
      // READ RULES
      // -----------------------------------------------------

      allow get: if isSignedIn() && (
        existing().passengerId == uid() ||
        existing().riderId == uid() ||
        existing().status == 'requested'
      );

      allow list: if isSignedIn();

      // -----------------------------------------------------
      // CREATE RIDE
      // -----------------------------------------------------

      allow create: if isSignedIn()
        && incoming().passengerId == uid()
        && isValidRide(incoming());

      // -----------------------------------------------------
      // UPDATE RIDE (SIMPLIFIED + SAFE LOGIC)
      // -----------------------------------------------------

      allow update: if isSignedIn() && (

        // Passenger cancels ride
        (existing().passengerId == uid()
          && existing().status == 'requested'
          && incoming().status == 'cancelled') ||

        // Rider accepts ride
        (getRole() == 'rider'
          && existing().status == 'requested'
          && incoming().status == 'accepted'
          && incoming().riderId == uid()) ||

        // Rider updates ride (arrived/ongoing/etc.)
        (existing().riderId == uid()) ||

        // Passenger completes & rates ride
        (existing().passengerId == uid()
          && existing().status == 'completed'
          && incoming().riderRating is number
          && incoming().riderRating >= 1
          && incoming().riderRating <= 5)
      );

      allow delete: if false;
    }

    // =====================================================
    // PROMO CODES
    // =====================================================

    match /promoCodes/{codeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}